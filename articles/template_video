<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Article - Vidéo</title>

<meta property="og:title" content="Film immersif">
<meta property="og:description" content="Expérience vidéo">
<meta property="og:image" content="https://tonsite.com/images/preview-video.jpg">
<meta property="og:type" content="website">

<style>
body { margin:0; background:#000; overflow:hidden; }

video {
  position:fixed;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
}

.overlay {
  position:fixed;
  bottom:40px;
  left:40px;
  color:white;
  background:rgba(0,0,0,0.4);
  padding:20px;
  backdrop-filter: blur(10px);
}
</style>
</head>
<body>

<video autoplay loop playsinline controls>
  <source src="videos/film.mp4" type="video/mp4">
</video>

<div class="overlay">
  <h1>Film immersif</h1>
  <p>Une expérience totale</p>
</div>

</body>
</html>
